# === 基础TARGET配置 ===
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y

# === 设备启用 ===
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=y

# === 包组定义 ===
CONFIG_PACKAGE_GROUP_BASE="netspeedtest samba4 smbuser tailscale taskplan ttyd upnp zram-swap"
CONFIG_PACKAGE_GROUP_ATHENA_LITE="openclash easytier lucky partexp quickfile"
CONFIG_PACKAGE_GROUP_ATHENA_FULL="ddns-go homeproxy istorex"

# === 亚瑟系列配置 ===
# 亚瑟Lite
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01_lite="netspeedtest samba4 smbuser tailscale taskplan ttyd upnp zram-swap nikki"
# 亚瑟OC
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01_oc="netspeedtest samba4 smbuser tailscale taskplan ttyd upnp zram-swap openclash"
# 亚瑟Full(雅典娜Lite)
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01="netspeedtest samba4 smbuser tailscale taskplan ttyd upnp zram-swap openclash easytier lucky partexp quickfile"

# === 雅典娜系列配置 ===
# 雅典娜Lite(与亚瑟Full相同)
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02_lite="netspeedtest samba4 smbuser tailscale taskplan ttyd upnp zram-swap openclash easytier lucky partexp quickfile"
# 雅典娜Full
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02="netspeedtest samba4 smbuser tailscale taskplan ttyd upnp zram-swap openclash easytier lucky partexp quickfile ddns-go homeproxy istorex"

# === 设备特定包 ===
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01+=" ipq-wifi-jdcloud_re-ss-01"
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02+=" ipq-wifi-jdcloud_re-cs-02 ath11k-firmware-qcn9074 kmod-ath11k-pci luci-app-athena-led luci-i18n-athena-led-zh-cn"

# === 启用子配置 ===
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01_lite=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01_oc=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02_lite=y

CONFIG_TARGET_ROOTFS_INITRAMFS=n

# === 编译优化 ===
CONFIG_USE_APK=n
CONFIG_DEVEL=y
CONFIG_CCACHE=y
CONFIG_TARGET_OPTIONS=y
CONFIG_TARGET_OPTIMIZATION="-O2 -pipe -march=armv8-a+crc+crypto -mtune=cortex-a53 -mcpu=cortex-a53 -mfix-cortex-a53-835769 -mfix-cortex-a53-843419"
CONFIG_TOOLCHAINOPTS=y
CONFIG_GCC_USE_VERSION_13=y
CONFIG_GDB=n

# === BUSYBOX ===
CONFIG_BUSYBOX_CUSTOM=y
CONFIG_BUSYBOX_CONFIG_TELNET=y

# === Swap ===
CONFIG_PACKAGE_zram-swap=m

# === NSS配置 ===
CONFIG_IPQ_MEM_PROFILE_256=y
CONFIG_ATH11K_MEM_PROFILE_512M=y
CONFIG_NSS_MEM_PROFILE_HIGH=y
CONFIG_NSS_FIRMWARE_VERSION_11_4=y
CONFIG_PACKAGE_sqm-scripts-nss=y
CONFIG_PACKAGE_kmod-qca-mcs=y
CONFIG_KERNEL_SKB_RECYCLER=y
CONFIG_KERNEL_SKB_RECYCLER_MULTI_CPU=y
CONFIG_PACKAGE_kmod-ath11k-pci=m
CONFIG_NSS_DRV_WIFI_MESH_ENABLE=y
CONFIG_PACKAGE_MAC80211_MESH=y
CONFIG_ATH11K_NSS_MESH_SUPPORT=y

# === 网络协议 ===
CONFIG_PACKAGE_proto-bonding=y
CONFIG_PACKAGE_luci-proto-relay=y

# === 内核模块 ===
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-netlink-diag=y
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-tls=y
CONFIG_PACKAGE_kmod-tun=y

# === USB支持 ===
CONFIG_PACKAGE_kmod-usb-acm=y
CONFIG_PACKAGE_kmod-usb-ehci=y
CONFIG_PACKAGE_kmod-usb-net-huawei-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-net-ipheth=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y
CONFIG_PACKAGE_kmod-usb-net-asix-ax88179=y
CONFIG_PACKAGE_kmod-usb-net-rtl8152=y
CONFIG_PACKAGE_kmod-usb-net-sierrawireless=y
CONFIG_PACKAGE_kmod-usb-ohci=y
CONFIG_PACKAGE_kmod-usb-serial-qualcomm=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-extras=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-usb2=y

# === 库文件 ===
CONFIG_PACKAGE_luci-lib-ipkg=y
CONFIG_PACKAGE_libopenssl-legacy=y

# === 性能测试 ===
CONFIG_PACKAGE_coremark=y
CONFIG_COREMARK_OPTIMIZE_O3=y
CONFIG_COREMARK_ENABLE_MULTITHREADING=y
CONFIG_COREMARK_NUMBER_OF_THREADS=6

# === 防火墙 ===
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_ip6tables-nft=y

# === ZqinKing包 ===
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_fuse-utils=y
CONFIG_PACKAGE_ntfs3-mount=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_sgdisk=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_PACKAGE_resize2fs=y
CONFIG_PACKAGE_qrencode=y
CONFIG_PACKAGE_smartmontools-drivedb=y
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_usbmuxd=y
CONFIG_PACKAGE_mii-tool=y
CONFIG_PACKAGE_default-settings=y
CONFIG_PACKAGE_default-settings-chn=y

# === Mary定制包 ===
# ==== 自由工具 ====
# HomeProxy
CONFIG_PACKAGE_homeproxy=m
CONFIG_PACKAGE_luci-app-homeproxy=m
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=m
# OpenClash
CONFIG_PACKAGE_openclash=m
CONFIG_PACKAGE_luci-app-openclash=m
# Nikki
CONFIG_PACKAGE_nikki=m
CONFIG_PACKAGE_luci-app-nikki=m
CONFIG_PACKAGE_luci-i18n-nikki-zh-cn=m
# ==== VPN工具 ====
# EasyTier
CONFIG_PACKAGE_easytier=m
CONFIG_PACKAGE_luci-app-easytier=m
# Tailscale
CONFIG_PACKAGE_tailscale=m
CONFIG_PACKAGE_luci-app-tailscale=m
CONFIG_PACKAGE_luci-i18n-tailscale-zh-cn=m

# ==== 其它工具 ====
# 网络速度测试
CONFIG_PACKAGE_netspeedtest=m
CONFIG_PACKAGE_luci-app-netspeedtest=m
# 文件共享(Samba)
CONFIG_PACKAGE_samba4=m
CONFIG_PACKAGE_luci-app-samba4=m
# SMB用户管理
CONFIG_PACKAGE_smbuser=m
CONFIG_PACKAGE_luci-app-smbuser=m
# 定时任务
CONFIG_PACKAGE_taskplan=m
CONFIG_PACKAGE_luci-app-taskplan=m
# 终端访问
CONFIG_PACKAGE_ttyd=m
CONFIG_PACKAGE_luci-app-ttyd=m
# UPnP
CONFIG_PACKAGE_upnp=m
CONFIG_PACKAGE_luci-app-upnp=m
# Lucky
CONFIG_PACKAGE_lucky=m
CONFIG_PACKAGE_luci-app-lucky=m
# DDNS-go
CONFIG_PACKAGE_ddns-go=m
CONFIG_PACKAGE_luci-app-ddns-go=m
# 分区扩容
CONFIG_PACKAGE_partexp=m
CONFIG_PACKAGE_luci-app-partexp=m
# 快速文件
CONFIG_PACKAGE_quickfile=m
CONFIG_PACKAGE_luci-app-quickfile=m
# iStoreX
CONFIG_PACKAGE_istorex=m
CONFIG_PACKAGE_luci-app-istorex=m
# 雅典娜LED
CONFIG_PACKAGE_luci-app-athena-led=m
CONFIG_PACKAGE_luci-i18n-athena-led-zh-cn=m
